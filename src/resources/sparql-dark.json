{
  "$schema": "vscode://schemas/color-theme",
  "name": "SPARQL Dark",
  "type": "dark",
  "tokenColors": [
    {
      "name": "SPARQL structural keywords (SELECT, WHERE, PREFIX…)",
      "scope": ["keyword.control.sparql", "keyword.operator.prefixdecl.sparql"],
      "settings": { "foreground": "#6c71c4" }
    },
    {
      "name": "SPARQL built-in functions (FILTER, BIND, STR, LANG…)",
      "scope": "keyword.operator.function.sparql",
      "settings": { "foreground": "#268bd2" }
    },
    {
      "name": "Prefixed names / CURIE namespace part",
      "scope": ["variable.prefix.sparql", "variable.reference.sparql"],
      "settings": { "foreground": "#cb4b16", "fontStyle": "italic" }
    },
    {
      "name": "SPARQL variables (?x, ?name…)",
      "scope": "variable.other.sparql",
      "settings": { "foreground": "#7a9bb5" }
    },
    {
      "name": "Full IRIs (<http://…>)",
      "scope": "constant.other.iri.sparql",
      "settings": { "foreground": "#2aa198" }
    },
    {
      "name": "Numeric literals",
      "scope": "constant.numeric",
      "settings": { "foreground": "#2aa198" }
    },
    {
      "name": "String literals",
      "scope": "string",
      "settings": { "foreground": "#b58900" }
    },
    {
      "name": "Punctuation / symbols",
      "scope": "keyword.symbol",
      "settings": { "foreground": "#586e75", "fontStyle": "bold" }
    },
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#586e75", "fontStyle": "italic" }
    }
  ]
}
