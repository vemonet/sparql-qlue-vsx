{
  "name": "sparql-qlue",
  "displayName": "SPARQL Qlue",
  "description": "Language server for SPARQL with qlue-ls (syntax highlighting, autocomplete, formatting), and query execution",
  "version": "0.0.1",
  "publisher": "vemonet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vemonet/sparql-qlue-vsx"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters",
    "Themes"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sparql",
        "aliases": [
          "SPARQL",
          "sparql"
        ],
        "extensions": [
          ".rq",
          ".sparql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sparql",
        "scopeName": "source.sparql",
        "path": "./src/resources/sparql.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "SPARQL Dark",
        "uiTheme": "vs-dark",
        "path": "./src/resources/sparql-dark.json"
      },
      {
        "label": "SPARQL Light",
        "uiTheme": "vs",
        "path": "./src/resources/sparql-light.json"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "sparql-qlue-panel",
          "title": "SPARQL Results",
          "icon": "$(play)"
        }
      ]
    },
    "views": {
      "sparql-qlue-panel": [
        {
          "type": "webview",
          "id": "sparql-qlue.queryPanel",
          "name": "SPARQL Results",
          "icon": "$(terminal)"
        }
      ]
    },
    "commands": [
      {
        "command": "sparql-qlue.executeQuery",
        "title": "Execute SPARQL Query",
        "icon": "$(play)"
      }
    ],
    "configuration": {
      "title": "SPARQL Qlue",
      "properties": {
        "sparql-qlue.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format SPARQL documents via the language server when saving."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "sparql-qlue.executeQuery",
          "when": "resourceLangId == sparql",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "sparql-qlue.executeQuery",
          "when": "resourceLangId == sparql",
          "group": "1_sparql"
        },
        {
          "command": "sparql-qlue.showQueryPanel",
          "when": "resourceLangId == sparql",
          "group": "1_sparql"
        }
      ],
      "explorer/context": [
        {
          "command": "sparql-qlue.executeQuery",
          "when": "resourceExtname == .rq || resourceExtname == .sparql",
          "group": "1_sparql"
        },
        {
          "command": "sparql-qlue.showQueryPanel",
          "when": "resourceExtname == .rq || resourceExtname == .sparql",
          "group": "1_sparql"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sparql-qlue.executeQuery",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "resourceLangId == sparql"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "package:vsce": "vsce package",
    "package:ovsx": "ovsx package",
    "publish:vsce": "vsce package && vsce publish",
    "publish:ovsx": "ovsx publish",
    "publish:all": "npm run publish:vsce && npm run publish:ovsx"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.9",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@zazuko/yasr": "^4.6.1",
    "qlue-ls": "^2.5.4",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5"
  }
}
